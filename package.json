{
  "name": "9rtm.dev",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "preview:cf": "pnpm run build && wrangler dev",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types src/worker-configuration.d.ts",
    "db:migrate": "wrangler d1 migrations apply 9rtm-dev-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply 9rtm-dev-db --remote"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.18.0",
    "@sveltejs/adapter-cloudflare": "^7.2.4",
    "@sveltejs/enhanced-img": "^0.10.3",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/animejs": "^3.1.13",
    "@types/node": "^25.0.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "mdsvex": "^0.12.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "svelte": "^5.53.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.1",
    "wrangler": "^4.54.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@fontsource-variable/funnel-display": "^5.2.6",
    "@fontsource-variable/geist-mono": "^5.2.6",
    "@fontsource-variable/m-plus-1": "^5.2.6",
    "@fontsource-variable/museomoderno": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans-jp": "^5.2.8",
    "@fontsource/line-seed-jp": "^5.2.1",
    "@lucide/svelte": "^0.525.0",
    "@threlte/core": "^8.1.3",
    "@threlte/extras": "^9.4.2",
    "@types/react": "^19.2.7",
    "@types/three": "^0.178.1",
    "animejs": "^4.1.2",
    "bits-ui": "^2.16.3",
    "date-fns": "^4.1.0",
    "pino": "^10.3.0",
    "postprocessing": "^6.38.2",
    "react": "^19.2.3",
    "rehype-slug": "^6.0.0",
    "rehype-unwrap-images": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "satori": "^0.18.3",
    "sharp": "^0.34.5",
    "shiki": "^3.21.0",
    "three": "^0.178.0",
    "zod": "^4.0.5"
  }
}
